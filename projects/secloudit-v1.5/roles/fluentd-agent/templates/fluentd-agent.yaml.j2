# roles/fluentd-agent/templates/fluentd-agent.yaml.j2
# FluentD Agent DaemonSet
# 각 K8s 노드에서 로그 수집 → Logging VM 전달

---
apiVersion: v1
kind: Namespace
metadata:
  name: kube-system
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: fluentd-agent
  namespace: kube-system
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: fluentd-agent
rules:
  - apiGroups: [""]
    resources: ["pods", "namespaces"]
    verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: fluentd-agent
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: fluentd-agent
subjects:
  - kind: ServiceAccount
    name: fluentd-agent
    namespace: kube-system
---
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: fluentd-agent
  namespace: kube-system
  labels:
    app: fluentd-agent
spec:
  selector:
    matchLabels:
      app: fluentd-agent
  template:
    metadata:
      labels:
        app: fluentd-agent
    spec:
      serviceAccountName: fluentd-agent
      tolerations:
        - key: node-role.kubernetes.io/master
          effect: NoSchedule
        - key: node-role.kubernetes.io/control-plane
          effect: NoSchedule
      containers:
        - name: fluentd
          image: {{ registry_host }}:{{ registry_port }}/secloudit/fluentd:{{ fluentd_version }}
          env:
            - name: FLUENT_FORWARD_HOST
              value: "{{ fluent_forward_host }}"  # TODO: 확인 필요
            - name: FLUENT_FORWARD_PORT
              value: "{{ fluent_forward_port }}"
            - name: CLUSTER_DIVIDE_VALUE
              value: "{{ cluster_divide_value }}"  # TODO: 확인 필요
          volumeMounts:
            - name: varlog
              mountPath: /var/log
            - name: varlibdockercontainers
              mountPath: /var/lib/docker/containers
              readOnly: true
          resources:
            limits:
              memory: 200Mi
            requests:
              cpu: 100m
              memory: 200Mi
      volumes:
        - name: varlog
          hostPath:
            path: /var/log
        - name: varlibdockercontainers
          hostPath:
            path: /var/lib/docker/containers
