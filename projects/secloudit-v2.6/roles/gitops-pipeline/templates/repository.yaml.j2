# ArgoCD에 secloudit-helm 레포 등록

apiVersion: v1
kind: Secret
metadata:
  name: secloudit-helm-repo
  namespace: {{ argocd_namespace }}
  labels:
    argocd.argoproj.io/secret-type: repository
stringData:
  type: git
  url: {{ secloudit_helm_repo_url }}
