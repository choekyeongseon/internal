---
# Kafka (신규)
# 설치 순서 7단계 (in-cluster)
# TODO: Kafka 버전 및 설정 확인 필요
# TODO: Strimzi Kafka Operator 또는 직접 배포 방식 확인 필요

apiVersion: v1
kind: Namespace
metadata:
  name: kafka
  labels:
    app.kubernetes.io/name: kafka
    app.kubernetes.io/component: messaging

---
# TODO: Kafka 전체 리소스 추가 필요
# 아래는 placeholder - 실제 배포 시 완성된 manifest로 교체
# 필요한 리소스:
# - Zookeeper StatefulSet (또는 KRaft 모드)
# - Kafka StatefulSet
# - Service (headless, bootstrap)
# - ConfigMap
# - PersistentVolumeClaim

apiVersion: v1
kind: ConfigMap
metadata:
  name: kafka-config
  namespace: kafka
data:
  # TODO: Kafka 설정값 확인 필요
  _placeholder: "true"

---
apiVersion: v1
kind: Service
metadata:
  name: kafka-bootstrap
  namespace: kafka
  labels:
    app: kafka
spec:
  type: ClusterIP
  ports:
    - name: kafka
      port: 9092
      targetPort: 9092
  selector:
    app: kafka
