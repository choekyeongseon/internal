---
# Alert Module (신규, Kafka 의존)
# 설치 순서 8단계 (in-cluster)
# TODO: Alert Module 버전 및 설정 확인 필요

apiVersion: v1
kind: Namespace
metadata:
  name: alert-module
  labels:
    app.kubernetes.io/name: alert-module
    app.kubernetes.io/component: alerting

---
apiVersion: v1
kind: ConfigMap
metadata:
  name: alert-module-config
  namespace: alert-module
data:
  # TODO: Alert Module 설정값 확인 필요
  KAFKA_BOOTSTRAP_SERVERS: "kafka-bootstrap.kafka.svc.cluster.local:9092"

---
# TODO: Alert Module 전체 리소스 추가 필요
# 아래는 placeholder - 실제 배포 시 완성된 manifest로 교체

apiVersion: apps/v1
kind: Deployment
metadata:
  name: alert-module
  namespace: alert-module
  labels:
    app: alert-module
spec:
  replicas: 1
  selector:
    matchLabels:
      app: alert-module
  template:
    metadata:
      labels:
        app: alert-module
    spec:
      containers:
        - name: alert-module
          image: {{ image_registry }}/secloudit/alert-module:latest  # TODO: 버전 확인
          envFrom:
            - configMapRef:
                name: alert-module-config
          ports:
            - containerPort: 8080
          resources:
            limits:
              memory: 512Mi
            requests:
              cpu: 100m
              memory: 256Mi

---
apiVersion: v1
kind: Service
metadata:
  name: alert-module
  namespace: alert-module
  labels:
    app: alert-module
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 8080
      targetPort: 8080
  selector:
    app: alert-module
